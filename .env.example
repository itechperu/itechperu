# ===========================================
# itechperu.shop — Variables de entorno
# ===========================================
# Copia este archivo a .env.local (desarrollo) o configúralo en el
# panel de Vercel (Project Settings → Environment Variables).
# NUNCA subas el .env real con secretos a GitHub.

# ---------- Base de datos (Prisma) ----------
#
# 📍 DESARROLLO LOCAL (SQLite):
#   DATABASE_URL="file:/home/z/my-project/db/custom.db"
#
# 📍 PRODUCCIÓN (Supabase PostgreSQL — RECOMENDADO):
#   1. Crea cuenta gratis en https://supabase.com
#   2. Crea un nuevo proyecto (región: São Paulo = menor latencia desde Perú)
#   3. Ve a Project Settings → Database → Connection string → URI
#   4. Copia la URL (reemplaza [YOUR-PASSWORD] con tu contraseña real)
#   5. Formato: postgresql://postgres.[ref]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
#
# El script scripts/select-prisma-provider.js detecta automáticamente
# si usar SQLite (file:) o PostgreSQL (postgres) según la URL.

# Dev (SQLite):
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# Prod (Supabase — descomenta y reemplaza):
# DATABASE_URL="postgresql://postgres.[TU-REF]:[TU-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# ---------- NextAuth.js ----------
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# 1. Crea OAuth 2.0 Client ID (tipo Web)
# 2. Authorized redirect URIs:
#    http://localhost:3000/api/auth/callback/google
#    https://itechperu.shop/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Mercado Pago ----------
# Obtén tus credenciales en https://www.mercadopago.com.pe/developers/panel/app
# Para pruebas: usa credenciales TEST (sandbox)
# Para producción: usa credenciales REALES (verifica tu cuenta con RUC)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""

# ---------- App ----------
NEXT_PUBLIC_SITE_URL="https://itechperu.shop"
NEXT_PUBLIC_BRAND="itechperu.shop"
WHATSAPP_NUMBER="51987654321"

# ---------- Supabase Storage (opcional, para imágenes de productos) ----------
# Solo necesario si quieres subir fotos de productos desde el admin
# NEXT_PUBLIC_SUPABASE_URL="https://[TU-REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

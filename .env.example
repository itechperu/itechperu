# ===========================================
# itechperu.shop — Variables de entorno
# ===========================================
# Copia este archivo a .env.local (desarrollo) o configúralo en el
# panel de Vercel (Project Settings → Environment Variables).
# NUNCA subas el .env real con secretos a GitHub.

# ---------- Base de datos (Prisma) ----------
# Desarrollo local: SQLite
DATABASE_URL="file:./dev.db"

# Producción (Vercel): PostgreSQL en Neon/Supabase
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/itechperu?schema=public"

# ---------- NextAuth.js ----------
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# 1. Crea un proyecto en Google Cloud Console
# 2. Habilita Google+ API
# 3. Crea OAuth 2.0 Client ID (tipo Web)
# 4. Authorized redirect URIs:
#    http://localhost:3000/api/auth/callback/google
#    https://itechperu.shop/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Mercado Pago ----------
# Obtén tus credenciales en https://www.mercadopago.com.pe/developers/panel/app
# 1. Crea una aplicación
# 2. Copia Access Token y Public Key
# 3. Para pruebas: usa las credenciales de TEST (sandbox)
# 4. Para producción: usa las credenciales REALES (debes verificar tu cuenta)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""

# ---------- App ----------
NEXT_PUBLIC_SITE_URL="https://itechperu.shop"
NEXT_PUBLIC_BRAND="itechperu.shop"
WHATSAPP_NUMBER="51987654321"

# ---------- Z.AI SDK (opcional, features AI) ----------
ZAI_API_KEY=""

# ---------- Google Sheets Sync (catálogo automático) ----------
# Permite sincronizar productos desde un Google Sheet cada hora.
# Ver README sección "Google Sheets Sync" para instrucciones completas.
#
# 1. Crear Service Account en Google Cloud Console
# 2. Habilitar Google Sheets API
# 3. Descargar JSON de credenciales
# 4. Copiar client_email y private_key del JSON
# 5. Compartir tu Google Sheet con ese email (permiso Lector)
# 6. Copiar el ID del sheet de la URL: docs.google.com/spreadsheets/d/[SHEET_ID]/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_SHEETS_ID=""
GOOGLE_SHEETS_RANGE="Catalogo!A:T"

# ---------- Vercel Cron (sync automático cada hora) ----------
# Cualquier string aleatorio largo (ej: openssl rand -hex 32)
CRON_SECRET=""

# ---------- Sanity (almacenamiento de imágenes — 100 GB gratis) ----------
# Sanity se usa SOLO para imágenes. Los datos siguen en Google Sheets + Postgres.
#
# 1. Crea cuenta en https://www.sanity.io/manage (gratis)
# 2. Crea un proyecto nuevo → obtén PROJECT_ID
# 3. Settings → API → Tokens → Create token (Permissions: Read+Write)
# 4. Copia el token
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_WRITE_TOKEN=""
